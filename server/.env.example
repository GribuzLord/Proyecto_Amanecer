PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=programa_ministerio
DB_USER=root
DB_PASSWORD=
# Pon en "true" cuando te conectes a un MySQL gestionado como Aiven (exige SSL).
# En desarrollo local normalmente lo dejas vacío o en "false".
DB_SSL=false

# En producción: la URL pública de tu frontend en Netlify (sin barra final).
# Restringe qué dominios pueden llamar a tu API. Déjalo vacío en desarrollo.
CLIENT_URL=

JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# Credenciales del primer admin (usadas solo por database/seed.js)
ADMIN_EMAIL=admin@congregacion.org
ADMIN_PASSWORD=CambiaEstaClave123!
ADMIN_NOMBRE=Administrador
